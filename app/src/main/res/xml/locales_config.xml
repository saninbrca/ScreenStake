<?xml version="1.0" encoding="utf-8"?>
<!-- Supported app languages for the Android 13+ per-app language picker
     (System Settings → Apps → Finite → Language). Must stay in sync with the
     res/values (en) and res/values-de locale folders and with the
     androidResources.localeFilters list in app/build.gradle.kts. -->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="de" />
</locale-config>
