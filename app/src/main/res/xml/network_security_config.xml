<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Block all cleartext (HTTP) traffic for the release build.
        All communication goes through HTTPS: Firebase, Stripe, Google APIs.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
