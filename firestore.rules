rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profile doc ──────────────────────────────────────────────────────
    // User can read/write their own profile. Stripe account fields are
    // Cloud-Function-only: the CF uses Admin SDK which bypasses these rules.
    match /users/{userId} {
      // Owner reads own doc; admin may read/list ALL users (dashboard user search).
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || request.auth.token.email == "sanin.brica@gmail.com");
      allow create: if request.auth != null && request.auth.uid == userId;
      // Owner self-update — Stripe + moderation (ban) fields are NOT client-writable.
      // (The ban fields must be CF/admin-only, else a banned user could self-unban
      //  within their token's 1h validity window.)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['stripeConnectedAccountId', 'stripeCustomerId',
                   'disabled', 'disabledReason', 'disabledAt']);
      // Admin may flip ONLY the ban flag fields (setUserBanStatus CF also does this
      // via Admin SDK, which bypasses rules — this is the defensive client path).
      allow update: if request.auth.token.email == "sanin.brica@gmail.com"
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['disabled', 'disabledReason', 'disabledAt']);
      allow delete: if false;
    }

    // ── Solo challenge docs (sub-collection under users) ──────────────────────
    // App creates challenge docs with paymentIntentId + amountCents after the
    // Stripe PaymentSheet completes. Post-creation, status/payout/Stripe fields
    // are immutable from the client — Cloud Functions own those writes.
    // Delete is allowed so the client can remove failed/cancelled challenges;
    // this prevents them from reappearing on the next Firestore sync (which
    // filters status="active" and would re-insert a still-active Firestore doc).
    match /users/{userId}/challenges/{challengeId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'status', 'payoutStatus', 'payoutAmount', 'appFeeAmount',
            'stripePaymentIntentId', 'stripeCustomerId',
            'finalPayout', 'endDate', 'startDate',
            'amountCents', 'paymentIntentId'
          ]);
      allow delete: if request.auth != null && request.auth.uid == userId;

      // ── Daily logs nested under a challenge (sub-collection) ───────────────
      // Written by saveDailyLog() / fetchDailyLogs() in FirestoreService.
      // Must be declared explicitly — parent challenge rules do NOT cover
      // sub-collections. Missing rule caused PERMISSION_DENIED on dailyLogs reads.
      match /dailyLogs/{logId} {
        // Money-critical: `limitExceeded` gates the Hard Mode win-refund in the
        // cancelOrRefundPayment Cloud Function. It must be tamper-evident, so:
        //  • create  — owner may create logs (worker writes false on clean days,
        //              true on a violation day).
        //  • update  — owner may update, EXCEPT flipping limitExceeded true → false
        //              (true means the stake should have been captured, not refunded).
        //              false → true is allowed (the worker may record a violation).
        //  • delete  — CF-ONLY. The onChallengeDeleted trigger cascades log cleanup
        //              via the Admin SDK; blocking client deletes stops a cheater from
        //              deleting an exceeded-day log to dodge the win-gate.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
          && !(resource.data.limitExceeded == true
               && request.resource.data.limitExceeded != true);
        allow delete: if false;
      }
    }

    // ── Challenges — admin collection-group read ──────────────────────────────
    // The per-user rule above (match /users/{userId}/challenges/{challengeId}) does
    // NOT authorise collectionGroup("challenges") queries — those are evaluated only
    // against recursive-wildcard rules. The admin dashboard (Übersicht "Heute",
    // Umsatz, recent-activity feed, backfillCounters fallback) needs to read EVERY
    // user's challenges, so grant the admin a collection-group read across all
    // `challenges` sub-collections at any path. This is ADDITIVE — the owner's
    // per-user read/create/update/delete rules above are unchanged, so normal users
    // still only access their own challenges.
    match /{path=**}/challenges/{challengeId} {
      allow read: if request.auth.token.email == "sanin.brica@gmail.com";
    }

    // ── Daily logs (flat sub-collection under users) ──────────────────────────
    // Written from Android every 10 s (consciousOpens, budgetUsedMs, etc.).
    // Full read/write for the owning user — no field restrictions needed here.
    match /users/{userId}/dailyLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Pending payouts (sub-collection under users) ──────────────────────────
    // Created and updated exclusively by Cloud Functions via Admin SDK.
    match /users/{userId}/pendingPayouts/{payoutId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Payment captures (sub-collection under users) ─────────────────────────
    // Written by capturePayment Cloud Function only.
    match /users/{userId}/paymentCaptures/{captureId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Permission status (sub-collection under users) ────────────────────────
    // Android client writes permissionLostAt/permissionType/deviceId on loss,
    // usageViolationDetectedAt/violatingPackage/usageMinutes on usage violation,
    // and clears permissionLostAt + sets permissionRestoredAt on restore.
    // capturedAt, captureReason, and usageCapturedAt are Cloud-Function-only fields.
    match /users/{userId}/permissionStatus/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['capturedAt', 'captureReason', 'usageCapturedAt']);
      allow delete: if false;
    }

    // ── Device security info (sub-collection under users) ─────────────────────
    // Android client writes isRooted/detectedAt. adminVerified is admin-only.
    match /users/{userId}/deviceInfo/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['adminVerified']);
    }

    // ── Group challenges ──────────────────────────────────────────────────────
    // Any authenticated user can read (join flow, leaderboard, real-time listener).
    // The canonical document is always created by the createGroupChallenge CF via
    // Admin SDK. The Android app only updates the participants array in real-time
    // (opensToday / timeUsedMinutes every 10 s) — that key is intentionally NOT
    // in the blocked list so the sync continues to work.
    match /groupChallenges/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && !request.resource.data.keys().hasAny([
          'status', 'startDate', 'endDate', 'completedAt',
          'prizePool', 'appFee', 'prizePerWinner', 'nobodyFailed',
          'authorizationExpiresAt'
        ]);
      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny([
            'status', 'startDate', 'endDate', 'completedAt',
            'prizePool', 'appFee', 'prizePerWinner', 'nobodyFailed',
            'authorizationExpiresAt'
          ]);
      allow delete: if false;

      // Taunts sub-collection — any participant can create, nobody can edit/delete.
      // Shape-hardening: createdAt must be a recent server-consistent epoch-millis value
      // (±5 min of request.time — the app writes System.currentTimeMillis()) and message is
      // length-capped. Blocks forged/backdated or oversized taunt spam without a client change.
      match /taunts/{tauntId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.createdAt is int
          && request.resource.data.createdAt >= request.time.toMillis() - 300000
          && request.resource.data.createdAt <= request.time.toMillis() + 300000
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 500;
        allow update, delete: if false;
      }

      // Participants sub-collection — future-proofing. Currently participants are
      // stored as an embedded array, not a sub-collection. If ever migrated, these
      // rules ensure each user can only write their own participant doc and cannot
      // touch status/payout/Stripe fields.
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == participantId;
        allow update: if request.auth != null
          && request.auth.uid == participantId
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              'status', 'payoutStatus', 'finalPayout',
              'amountCents', 'paymentIntentId'
            ]);
        allow delete: if false;
      }
    }

    // ── Payout requests ───────────────────────────────────────────────────────
    // User can create their own request (no status/paidAt on creation).
    // Updates are Cloud-Function/admin-only (marking as paid/rejected).
    match /payoutRequests/{requestId} {
      // A user reads their own requests; the admin may read/list ALL of them
      // (the dashboard queries the whole collection with no userId filter).
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.auth.token.email == "sanin.brica@gmail.com");
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && (!request.resource.data.keys().hasAny(['paidAt']))
        && (!request.resource.data.keys().hasAny(['status'])
            || request.resource.data.status == "pending");
      // Admin marks requests paid/rejected from the dashboard. Clients can't.
      allow update: if request.auth.token.email == "sanin.brica@gmail.com";
      allow delete: if false;
    }

    // ── Usernames (unique handle registry) ────────────────────────────────────
    // One doc per claimed @username; the doc id IS the lowercase username.
    // Any authed user can read (availability check). A user may only claim a
    // free name for themselves (uid must match, doc must not already exist).
    // Names are permanent — no updates or deletes from the client.
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    // ── Support tickets ───────────────────────────────────────────────────────
    // A user creates tickets for themselves (userId must match their uid) and can
    // read only their own. Resolving/listing tickets is admin-only, gated on the
    // admin's verified email. Tickets are never deleted.
    // NOTE: the admin `update` rule is unrestricted on fields, so the admin
    // dashboard's adminReply/adminReplyAt + status/resolvedAt writes are covered.
    // adminReply lives on the ticket doc (the user CAN read it via direct Firestore
    // access, but the app never surfaces it) — truly private content goes in the
    // adminNotes sub-collection below instead.
    match /supportTickets/{ticketId} {
      // Shape-hardening (anti-abuse, no volume counter): createdAt must be a recent
      // server-consistent epoch-millis value (±5 min of request.time — blocks forged/backdated
      // timestamps without a client change, since the app writes System.currentTimeMillis()), and
      // subject/message are length-capped. The app already requires subject+message >= 10 chars.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt is int
        && request.resource.data.createdAt >= request.time.toMillis() - 300000
        && request.resource.data.createdAt <= request.time.toMillis() + 300000
        && request.resource.data.subject is string
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, list: if request.auth.token.email == "sanin.brica@gmail.com";
      allow delete: if false;

      // ── Internal admin notes (private) ──────────────────────────────────────
      // Lives in its own sub-collection so the ticket owner can NEVER read it
      // (the parent ticket read rule does NOT cascade to sub-collections).
      // Admin-only read AND write, gated on the admin's verified email.
      match /adminNotes/{noteId} {
        allow read, write: if request.auth.token.email == "sanin.brica@gmail.com";
      }
    }

    // ── Anti-cheat reviews (admin moderation decisions) ──────────────────────
    // One doc per reviewed user (doc id = userId). Stores the admin's decision so a
    // cleared false-positive is not re-flagged as new on the next analysis. Written
    // by the admin dashboard; never accessible to normal users. The detectSuspiciousUsers
    // Cloud Function reads these via the Admin SDK (bypasses rules).
    match /antiCheatReviews/{userId} {
      allow read, write: if request.auth.token.email == "sanin.brica@gmail.com";
    }

    // ── Counters (dashboard statistics) ───────────────────────────────────────
    // Admin-only read. Writes are Cloud-Function-only (Admin SDK bypasses rules).
    match /counters/{doc} {
      allow read: if request.auth.token.email == "sanin.brica@gmail.com";
      allow write: if false;
    }

    // ── Broadcasts (admin → all users) ────────────────────────────────────────
    // Any authenticated client reads the latest active broadcast (shown once as a
    // Dashboard dialog). Only the admin may create/update/deactivate broadcasts.
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == "sanin.brica@gmail.com";
    }

    // ── Remote app config (single doc: config/app) ────────────────────────────
    // Any authenticated client may read (feature flags, maintenance, version gates).
    // Only the admin may write — flipping maintenance / force-update / feature flags.
    match /config/app {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == "sanin.brica@gmail.com";
    }

    // ── Rate limits (per-UID throttle store) ──────────────────────────────────
    // Written ONLY by the enforceRateLimit Cloud Function helper via the Admin SDK
    // (which bypasses these rules). Never client-accessible — a client must not be able
    // to read or reset its own throttle counters.
    match /rateLimits/{uid} {
      allow read, write: if false;
    }

    // ── Admin collection ──────────────────────────────────────────────────────
    // Never accessible from the client under any circumstances.
    match /admin/{document=**} {
      allow read, write: if false;
    }
  }
}
