rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user data: only the owning user can read and write their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Group challenges: any authenticated user can read (needed for join flow,
    // detail screen, and real-time snapshot listener).
    // Client writes are allowed for authenticated users (fire-and-forget local sync);
    // the canonical write is always performed by Cloud Functions via the Admin SDK.
    match /groupChallenges/{groupId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
