# Release signing credentials — copy this file to `keystore.properties` and fill in real values.
# `keystore.properties` is gitignored and must NEVER be committed.
#
# KEYSTORE_PATH is resolved relative to the project root (or use an absolute path).
KEYSTORE_PATH=release.keystore
KEYSTORE_PASSWORD=your_store_password
KEY_ALIAS=your_key_alias
KEY_PASSWORD=your_key_password
